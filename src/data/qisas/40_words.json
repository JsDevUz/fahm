{
  "وَلَمَّا سَارَ الرِّجَالُ بِقَمِيصِ يُوسُفَ إِلَى كَنْعَانَ": "erkaklar Yusufning ko'ylagi bilan Kan'onga yo'l olganda",
  "أَحَسَّ يَعْقُوبُ رَائِحَةَ يُوسُفَ": "Ya'qub Yusufning hidini sezdi",
  "وَقَالَ إِنِّي لَأَجِدُ رِيحَ يُوسُفَ": "men Yusufning hidini topyapman dedi",
  "قَالُوا تَاللَّهِ": "ular Allohga qasam dedilar",
  "إِنَّكَ لَفِي ضَلَالِكَ الْقَدِيمِ": "sen eski adashuvingdasan",
  "وَلَكِنْ كَانَ يَعْقُوبُ صَادِقاً": "lekin Ya'qub rostgo'y edi",
  "فَلَمَّا أَن جَاءَ الْبَشِيرُ أَلْقَاهُ عَلَى وَجْهِهِ": "xushxabarchi kelib uni yuziga tashlagach",
  "فَارْتَدَّ بَصِيرًا": "ko'zi ochiq holga qaytdi",
  "أَلَمْ أَقُل لَّكُمْ إِنِّي أَعْلَمُ مِنَ اللَّهِ مَا لَا تَعْلَمُونَ": "sizlarga men Allohdan sizlar bilmaydigan narsani bilaman demaganmidim",
  "قَالُوا يَا أَبَانَا": "ular ey otamiz dedilar",
  "اسْتَغْفِرْ لَنَا ذُنُوبَنَا": "gunohlarimiz uchun bizga mag'firat so'ra",
  "إِنَّا كُنَّا خَاطِئِينَ": "biz xato qilgan edik",
  "قَالَ سَوْفَ أَسْتَغْفِرُ لَكُمْ رَبِّي": "sizlar uchun Robbimdan mag'firat so'rayman dedi",
  "إِنَّهُ هُوَ الْغَفُورُ الرَّحِيمُ": "U mag'firatli va rahmlidir",
  "وَلَمَّا وَصَلَ يَعْقُوبُ إلى مِصْرَ": "Ya'qub Misrga yetib kelgach",
  "اسْتَقْبَلَهُ يُوسُفُ": "Yusuf uni kutib oldi",
  "وَلا تَسْأَلْ عَنْ فَرَحِهِمَا وَسُرُورِهِمَا": "ularning quvonchi haqida so'rama",
  "وَكَانَ يَوْماً مَشْهُوداً فِي مِصْرَ": "Misrda mashhur kun edi",
  "وَكَانَ يَوْماً مُبَارَكاً": "muborak kun edi",
  "وَرَفَعَ يُوسُفُ أَبَوَيْهِ عَلَى الْعَرْشِ": "Yusuf ota-onasini taxt ustiga ko'tardi",
  "وَوَقَعُوا كُلُّهُمْ سُجَّداً لِيُوسُفَ": "barchasi Yusuf uchun sajda qildilar",
  "وَقَالَ يُوسُفُ يَا أَبَتِ": "Yusuf ey otajon dedi",
  "هَذَا تَأْوِيلُ رُؤْيَايَ مِن قَبْلُ": "bu avvalgi tushimning ta'biri",
  "قَدْ جَعَلَهَا رَبِّي حَقًّا": "Robbim uni haq qildi",
  "إِنِّي رَأَيْتُ أَحَدَ عَشَرَ كَوْكَبًا": "men o'n bir yulduzni ko'rdim",
  "وَالشَّمْسَ وَالْقَمَرَ": "quyosh va oyni",
  "رَأَيْتُهُمْ لِي سَاجِدِينَ": "ularni menga sajda qilayotgan holda ko'rdim",
  "وَحَمِدَ يُوسُفُ اللَّهَ": "Yusuf Allohga hamd aytdi",
  "حَمْداً طَيِّباً كَثِيراً": "chiroyli ko'p hamd",
  "وَشَكَرَ يُوسُفُ عَلَى ذَلِكَ": "Yusuf buning uchun shukr qildi",
  "شُكْراً عَظِيماً": "buyuk shukr",
  "وَبَقِيَ يَعْقُوبُ وَآلُ يَعْقُوبَ فِي مِصْرَ": "Ya'qub va oilasi Misrda qoldilar",
  "زَمناً طَوِيلاً": "uzoq vaqt",
  "وَمَاتَ يَعْقُوبُ وَزَوْجُهُ فِي مِصْرَ": "Ya'qub va jufti Misrda vafot etdilar"
