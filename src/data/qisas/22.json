  "page": 33,
  "sentences": [
    {
      "ar": "وَرَجَعَ الْإِخْوَةُ إِلَى الْبَيْتِ، وَتَرَكُوا يُوسُفَ فِي الْبِئْرِ.",
      "tr": "Aka-ukalar uyga qaytishdi va Yusufni quduqda qoldirishdi.",
      "parts": [
        {
          "w": "وَرَجَعَ",
          "r": "فِعل مَاضٍ",
          "rc": "tf",
          "e": "وَرَجَعَ — وَ harfi atf bilan boshlanuvchi o'tgan zamon fe'li bo'lib, uchlik mujjarrad وَزن فَعَلَ dan yasalgan. Arab grammatikasida فِعل مَاضٍ gapirish vaqtidan oldin tugallangan harakatni bildiradi.",
          "uz": "qaytdi"
        },
        {
          "w": "الْإِخْوَةُ",
          "r": "فَاعِل",
          "rc": "tm",
          "e": "الْإِخْوَةُ — وَرَجَعَ fe'lining fili (fo'ili), marfu' holatida damma bilan keladi. Ular oldindan ma'lum aka-ukalar guruhidir.",
          "uz": "aka-ukalar"
        },
        {
          "w": "إِلَى",
          "r": "حَرف جَر",
          "rc": "tb",
          "e": "إِلَى yo'nalish bildiruvchi jar harfi.",
          "uz": "-ga / tomon"
